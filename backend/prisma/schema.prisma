// Prisma schema — run `npx prisma migrate dev` to create the database.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email String
  password String
  name String
  bio String
  profilePicture String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Booking {
  id        String   @id @default(cuid())
  userId String
  date DateTime
  time String
  service String
  notes String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tattoo {
  id        String   @id @default(cuid())
  title String
  description String
  imageUrl String
  tags String
  dateCreated DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  userId String
  tattooId String
  rating Int
  comment String
  dateCreated DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SearchQuery {
  id        String   @id @default(cuid())
  userId String
  query String
  dateCreated DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId String
  message String
  type String
  read Boolean
  dateCreated DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
